# SiteForge 后端环境变量配置模板
# 使用方法：
#   1. 复制为 .env:  cp .env.example .env
#   2. 按需修改以下配置项（特别是带 ⚠️ 标记的项）
#   3. 启动：docker compose up -d

# ============================================================================
# 1. 站点配置
# ============================================================================

# 站点主域名（⚠️ 必填，用于 Nginx server_name 与 License 域名校验）
# 本地一键部署可填 localhost
DOMAIN=localhost

# 管理后台访问域名（默认与 DOMAIN 相同，可配置独立子域名如 admin.example.com）
ADMIN_DOMAIN=${DOMAIN}

# 是否启用 HTTPS（生产环境强烈建议启用；首次部署若未配置证书可设为 false）
HTTPS_ENABLED=false

# Nginx 对外端口（容器内仍为 80/443，仅修改宿主机映射）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================================
# 2. 数据库（PostgreSQL）
# ============================================================================

# 数据库名称
POSTGRES_DB=siteforge

# 数据库用户名
POSTGRES_USER=siteforge

# 数据库密码（⚠️ 必填，请使用强密码；本地一键部署可使用默认值）
POSTGRES_PASSWORD=siteforge123

# 数据库连接字符串（自动拼接，一般无需修改）
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# 数据库端口（容器内部，一般无需修改；默认不对外暴露）
POSTGRES_PORT=5432

# ============================================================================
# 3. Redis
# ============================================================================

# Redis 密码（⚠️ 建议设置；本地一键部署可使用默认值）
REDIS_PASSWORD=siteforge-redis

# Redis 连接字符串（自动拼接）
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ============================================================================
# 4. 应用服务
# ============================================================================

# 后端服务监听端口（容器内部）
PORT=3000

# 环境标识：development / staging / production
NODE_ENV=production

# CORS 允许的来源（生产环境建议设置为 https://${DOMAIN}）
CORS_ORIGIN=*

# 是否启用 Swagger 文档（生产环境建议关闭）
SWAGGER_ENABLED=true

# ============================================================================
# 5. JWT 认证
# ============================================================================

# JWT 签名密钥（⚠️ 必填，请使用足够长的随机字符串！）
# 生成命令：openssl rand -base64 64
# 本地一键部署可使用默认值，生产环境务必替换
JWT_SECRET=change-this-in-production

# JWT 过期时间
JWT_EXPIRES_IN=24h

# ============================================================================
# 6. License 授权
# ============================================================================

# License Key（可选，部分场景用于绑定授权；多数情况下留空即可）
LICENSE_KEY=

# License 严格模式（true: License 失效时管理功能锁定；false: 仅警告不锁定，开发环境用）
LICENSE_STRICT_MODE=true

# RSA 公钥（PEM 格式，用于验证 License 签名）
# 生产环境：将我方签发的公钥粘贴到此处，或挂载为文件后通过路径引用
LICENSE_RSA_PUBLIC_KEY=

# RSA 私钥（PEM 格式，仅用于本地开发签发 License，生产环境请留空）
LICENSE_RSA_PRIVATE_KEY=

# License 到期前提醒天数
LICENSE_EXPIRE_WARN_DAYS=7

# ============================================================================
# 7. 文件存储
# ============================================================================

# 媒体文件存储目录（容器内路径，对应 volume 挂载）
MEDIA_DIR=/app/data/media
# 别名（部分场景使用 UPLOAD_DIR 命名，与 MEDIA_DIR 等价）
UPLOAD_DIR=/app/data/media

# 静态站点产物目录（SSG 输出，对应 volume 挂载）
SITES_DIR=/app/data/sites

# ============================================================================
# 8. 备份
# ============================================================================

# 备份目录
BACKUP_DIR=/app/data/backups

# 备份保留份数
BACKUP_RETENTION_DAYS=7
