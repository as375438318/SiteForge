---
/**
 * ProductGrid 区块 - 产品网格
 * 数据来源：Astro Content Collections（products）
 * 语义化：<section> + <h2> + <article> per product
 */
import Placeholder from './Placeholder.astro'
import type { ProductGridProps } from '@shared/block-schema'
import { getCollection } from 'astro:content'

interface Props extends ProductGridProps {}
const {
  title,
  collection = 'products',
  limit = 6,
  showPrice = true,
  showCategory = true,
} = Astro.props

let entries: Array<{
  slug: string
  data: { title: string; summary?: string; coverImage?: string; price?: string; category?: string }
}> = []

try {
  const raw = await getCollection(collection as any)
  entries = raw
    .filter((e: any) => e.data.status !== 'draft')
    .slice(0, limit)
    .map((e: any) => ({ slug: e.slug, data: e.data }))
} catch {
  // collection 不存在时静默降级到占位
}
---
<section class="block-product-grid">
  <h2>{title ?? '产品服务'}</h2>
  <div class="product-grid" id="product-list">
    {entries.length === 0 ? (
      <Placeholder text="产品列表将自动从 CMS 内容生成" />
    ) : (
      entries.map((entry) => (
        <article class="product-card">
          {entry.data.coverImage && (
            <a href={`/${collection}/${entry.slug}`}>
              <img src={entry.data.coverImage} alt={entry.data.title} loading="lazy" />
            </a>
          )}
          <div class="product-card-body">
            {showCategory && entry.data.category && (
              <span class="product-category">{entry.data.category}</span>
            )}
            <h3>
              <a href={`/${collection}/${entry.slug}`}>{entry.data.title}</a>
            </h3>
            {entry.data.summary && <p>{entry.data.summary}</p>}
            {showPrice && entry.data.price && (
              <div class="product-price">{entry.data.price}</div>
            )}
          </div>
        </article>
      ))
    )}
  </div>
</section>
