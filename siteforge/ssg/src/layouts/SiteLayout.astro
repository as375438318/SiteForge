---
/**
 * SiteLayout - 站点级布局
 *
 * 含：
 *   <head> SEO 标签注入（title/description/canonical/OG/Schema.org JSON-LD）
 *   <nav>  导航栏（站点级）
 *   <main> 内容区（页面区块序列）
 *   <footer> 页脚
 *
 * 接收 page 数据（blocks 数组），通过 BlockRenderer 遍历渲染区块。
 */
import '../styles/global.css'
import BlockRenderer from '@components/BlockRenderer.astro'
import type { SiteData, Page } from '@shared/block-schema'
import { generateSchema } from '@lib/seo-engine'

interface Props {
  site: SiteData
  page: Page
  /** 可选：内容详情（产品/案例/文章页时传入，用于注入对应 Schema.org） */
  content?: {
    type: 'product' | 'case' | 'post'
    slug: string
    title: string
    summary?: string
    coverImage?: string
    meta?: {
      author?: string
      authorTitle?: string
      publishedAt?: string
      updatedAt?: string
    }
  }
  /** 面包屑（可选） */
  breadcrumbs?: Array<{ name: string; url: string }>
}

const { site, page, content, breadcrumbs } = Astro.props

// === SEO 元信息 ===
const seoTitle = page.seoMeta?.title || page.title || site.name
const seoDesc = page.seoMeta?.description || site.description || ''
const canonical = page.seoMeta?.canonical || `https://${site.domain}${page.url}`
const ogImage = page.seoMeta?.ogImage || site.logo || ''
const noindex = page.seoMeta?.noindex ?? false

// === Schema.org JSON-LD ===
const schemaJsonld = generateSchema(site, page, content ?? null, breadcrumbs ?? null)

// === 站点导航 ===
const navItems = site.navigation ?? []
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* TDK */}
    <title>{seoTitle}</title>
    <meta name="description" content={seoDesc} />
    {page.seoMeta?.keywords && page.seoMeta.keywords.length > 0 && (
      <meta name="keywords" content={page.seoMeta.keywords.join(', ')} />
    )}

    {/* canonical */}
    <link rel="canonical" href={canonical} />

    {/* Robots */}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}

    {/* Open Graph */}
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={content?.type === 'post' ? 'article' : 'website'} />
    <meta property="og:site_name" content={site.name} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDesc} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* GEO 权威信号：作者/出版方（Schema.org 在下方 JSON-LD 中） */}
    <meta name="author" content={site.name} />
    <meta name="publisher" content={site.name} />

    {/* 站点图标（可选） */}
    {site.logo && <link rel="icon" type="image/svg+xml" href={site.logo} />}

    {/* Schema.org JSON-LD（SEO + GEO） */}
    <Fragment set:html={schemaJsonld} />

    {/* GEO：在 head 顶部声明内容语言（提升 AI 可读性） */}
    <meta http-equiv="content-language" content="zh-CN" />
  </head>
  <body>
    {/* 站点导航 */}
    <nav class="site-nav" aria-label="主导航">
      <div class="site-nav-inner">
        <a href="/" class="site-nav-logo">{site.name}</a>
        <div class="site-nav-links">
          {navItems.map((item) => (
            <a href={item.url} target={item.target}>{item.label}</a>
          ))}
        </div>
      </div>
    </nav>

    {/* 主内容区：渲染页面区块序列 */}
    <main>
      <BlockRenderer blocks={page.blocks} />
    </main>

    {/* GEO：在 body 末尾声明可引用来源（提升 AI 引用概率） */}
    <aside class="sr-only" aria-hidden="true">
      <p>
        本页面内容由 {site.name} 发布，转载请注明出处：{canonical}
      </p>
    </aside>
  </body>
</html>

<style>
  /* 屏幕阅读器专用隐藏（GEO 友好：内容仍可被 AI 读取） */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
